@page
@model DocumentsModel

<button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
    Upload Document
</button>

<hr />

<div id="documentsContainer">
    @await Html.PartialAsync("_ViewDocuments", Model.Documents)
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" enctype="multipart/form-data" asp-page-handler="Upload">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Upload Document</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label>Document Type</label>
                        <select asp-for="Upload.FileType" class="form-select" required>
                            <option value="">-- Select --</option>
                            <option value="ID Proof">ID Proof</option>
                            <option value="Address Proof">Address Proof</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Select File</label>
                        <input type="file" asp-for="Upload.File" class="form-control" required />
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-success" type="submit">Upload</button>
                </div>
            </div>
        </form>
    </div>
</div>








public class UploadedDocument
{
    public int Id { get; set; }
    public string FileName { get; set; }
    public string FileType { get; set; }
    public string FilePath { get; set; }
    public DateTime UploadedOn { get; set; }
}









@model List<UploadedDocument>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>File Name</th>
            <th>Type</th>
            <th>Uploaded On</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var doc in Model)
        {
            <tr>
                <td>
                    <a href="@doc.FilePath" target="_blank">@doc.FileName</a>
                </td>
                <td>@doc.FileType</td>
                <td>@doc.UploadedOn.ToString("MM/dd/yyyy")</td>
                <td>
                    <form method="post" asp-page-handler="Delete">
                        <input type="hidden" name="id" value="@doc.Id" />
                        <button class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>










public class DocumentsModel : PageModel
{
    private readonly IWebHostEnvironment _env;

    public DocumentsModel(IWebHostEnvironment env)
    {
        _env = env;
    }

    public List<UploadedDocument> Documents { get; set; } = new();

    [BindProperty]
    public UploadInput Upload { get; set; }

    public void OnGet()
    {
        LoadDocuments();
    }

    public IActionResult OnPostUpload()
    {
        if (!ModelState.IsValid) return RedirectToPage();

        var uploadsFolder = Path.Combine(_env.WebRootPath, "uploads");
        Directory.CreateDirectory(uploadsFolder);

        var fileName = $"{Guid.NewGuid()}_{Upload.File.FileName}";
        var filePath = Path.Combine(uploadsFolder, fileName);

        using var stream = new FileStream(filePath, FileMode.Create);
        Upload.File.CopyTo(stream);

        // Save metadata (DB recommended)
        DocumentsStore.Add(new UploadedDocument
        {
            Id = DocumentsStore.NextId(),
            FileName = Upload.File.FileName,
            FileType = Upload.FileType,
            FilePath = $"/uploads/{fileName}",
            UploadedOn = DateTime.Now
        });

        return RedirectToPage();
    }

    public IActionResult OnPostDelete(int id)
    {
        var doc = DocumentsStore.Get(id);
        if (doc != null)
        {
            var fullPath = Path.Combine(_env.WebRootPath, doc.FilePath.TrimStart('/'));
            if (System.IO.File.Exists(fullPath))
                System.IO.File.Delete(fullPath);

            DocumentsStore.Delete(id);
        }

        return RedirectToPage();
    }

    private void LoadDocuments()
    {
        Documents = DocumentsStore.All();
    }
}





public class UploadInput
{
    [Required]
    public string FileType { get; set; }

    [Required]
    public IFormFile File { get; set; }
}
